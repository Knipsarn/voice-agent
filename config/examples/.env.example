OPENAI_API_KEY=
GOOGLE_CLOUD_PROJECT=
DEFAULT_TENANT_ID=example-company
DEFAULT_REALTIME_MODEL=gpt-realtime-1.5
FIRESTORE_COLLECTION_TENANTS=tenants
FIRESTORE_COLLECTION_PHONE_ROUTES=phone_number_routes
GCS_AUDIO_BUCKET=voice-assets

# Local tenant config directory (used before Firestore is integrated)
# If running from repo root: ./config/tenants
# If TENANT_CONFIG_DIR is not set, tenantLoader resolves from its own __dirname
TENANT_CONFIG_DIR=./config/tenants
